{
  /**
   * @file Конфигурация shadcn/ui
   * @description Этот файл определяет настройки библиотеки компонентов shadcn/ui:
   *   — стиль и цветовая схема
   *   — пути к UI-компонентам и утилитам
   *   — настройки Tailwind CSS и иконок
   *   — настройки редактора меню (menuColor / menuAccent)
   *
   * shadcn/ui — это не npm-пакет, а коллекция переиспользуемых React-компонентов,
   * которые копируются в ваш проект и кастомизируются под вашу дизайн-систему.
   */

  /**
   * Ссылка на JSON-схему валидации этого файла.
   * Используется редакторами (VS Code) для автодополнения и проверки полей.
   */
  "$schema": "https://ui.shadcn.com/schema.json",

  /**
   * Стиль компонентов.
   * "base-nova" — современный стиль (2025+), наследник new-york.
   * Определяет скругления, тени, отступы по умолчанию.
   * Другие варианты: "default", "new-york".
   */
  "style": "base-nova",

  /**
   * Флаг React Server Components (RSC).
   * true — компоненты по умолчанию серверные ("use server").
   * Если false — все компоненты клиентские ("use client").
   * В проектах на Next.js App Router должно быть true.
   */
  "rsc": true,

  /**
   * Использовать TypeScript (.tsx) для генерации компонентов.
   * true — все компоненты создаются с расширением .tsx и типами.
   */
  "tsx": true,

  /**
   * Настройки Tailwind CSS.
   * Определяют, как shadcn/ui стилизует компоненты.
   */
  "tailwind": {
    /**
     * Путь к конфигурационному файлу Tailwind.
     * Пустая строка "" — Tailwind v4 использует CSS-конфигурацию (globals.css),
     * а не tailwind.config.js.
     */
    "config": "",

    /**
     * Путь к глобальному CSS-файлу, где подключаются слои Tailwind:
     * @import "tailwindcss";
     * и определяются CSS-переменные для кастомизации темы.
     */
    "css": "src/app/globals.css",

    /**
     * Базовая цветовая схема для генерации оттенков.
     * "neutral" — серые тона;
     * "slate" — синевато-серые;
     * "stone" — тёплые серые;
     * "gray", "zinc" — другие варианты.
     */
    "baseColor": "neutral",

    /**
     * Использовать CSS-переменные для цветов темы.
     * true — цвета определяются как --primary, --secondary, --background и т.д.
     * Позволяет легко переключать тёмную тему (dark mode) и кастомизировать палитру.
     */
    "cssVariables": true,

    /**
     * Префикс для всех Tailwind-классов shadcn/ui.
     * Пустая строка — без префикса (обычные классы: flex, bg-primary).
     * Если указать "tw-", классы будут выглядеть как tw-flex, tw-bg-primary.
     * Полезно при использовании shadcn/ui вместе с другой CSS-библиотекой.
     */
    "prefix": ""
  },

  /**
   * Библиотека иконок для компонентов.
   * "lucide" — набор иконок Lucide React (наиболее популярный для shadcn/ui).
   * Альтернативы: "radix-icons", "phosphor" и др.
   */
  "iconLibrary": "lucide",

  /**
   * Поддержка RTL (right-to-left) для арабского/иврита.
   * false — проект использует стандартное LTR-направление.
   */
  "rtl": false,

  /**
   * Алиасы путей для импорта компонентов и утилит.
   * Соответствуют настройкам tsconfig.json (алиас @/).
   * Используются CLI shadcn/ui для генерации импортов в новых компонентах.
   */
  "aliases": {
    "components": "@/components",       // Все компоненты проекта
    "utils": "@/lib/utils",             // Утилитарные функции (cn, cv)
    "ui": "@/components/ui",            // shadcn/ui-компоненты (Button, Input, Card...)
    "lib": "@/lib",                     // Библиотечные модули
    "hooks": "@/hooks"                  // React-хуки (useMediaQuery, useDebounce...)
  },

  /**
   * Цвет темы боковой панели (sidebar).
   * "default" — стандартный цвет для sidebar.
   */
  "menuColor": "default",

  /**
   * Акцентный цвет меню (hover/active/focus на элементах навигации).
   * "subtle" — минималистичный акцент, почти незаметный.
   */
  "menuAccent": "subtle",

  /**
   * Реестры (registries) дополнительных компонентов.
   * Пустой объект {} — используются только базовые компоненты shadcn/ui.
   * Сюда можно добавлять ссылки на кастомные registry (например, nyxb/ui).
   */
  "registries": {}
}
